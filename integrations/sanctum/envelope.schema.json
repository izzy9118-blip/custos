{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimal Custos Sanctum Inquiry Envelope",
  "type": "object",
  "required": [
    "inquiry_id",
    "question"
  ],
  "properties": {
    "inquiry_id": {
      "type": "string"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "requested_by": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
