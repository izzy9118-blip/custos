{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Projection Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_id",
    "repository_full_name",
    "git_commit",
    "cognitive_memory_manifest_id",
    "projector_version",
    "schema_versions",
    "source_file_count",
    "node_counts",
    "relationship_counts",
    "validation_status",
    "integrity_sha256",
    "build_timestamp"
  ],
  "properties": {
    "projection_id": {
      "type": "string"
    },
    "repository_full_name": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "git_commit": {
      "type": "string",
      "minLength": 7
    },
    "cognitive_memory_manifest_id": {
      "type": "string"
    },
    "projector_version": {
      "type": "string"
    },
    "schema_versions": {
      "type": "object",
      "minProperties": 1
    },
    "source_file_count": {
      "type": "integer",
      "minimum": 0
    },
    "node_counts": {
      "type": "object"
    },
    "relationship_counts": {
      "type": "object"
    },
    "validation_status": {
      "enum": [
        "PASS",
        "FAIL",
        "WARNING"
      ]
    },
    "integrity_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "build_timestamp": {
      "type": "string"
    }
  }
}