{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Documentary Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observation_id",
    "canonical_class",
    "source_passage",
    "witness",
    "location_ids",
    "exact_feature",
    "context",
    "recovery_method",
    "epistemic_classification",
    "provenance_ids"
  ],
  "properties": {
    "observation_id": {
      "type": "string"
    },
    "canonical_class": {
      "const": "Observation"
    },
    "source_passage": {
      "type": "object"
    },
    "witness": {
      "type": "object"
    },
    "location_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "exact_feature": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "recovery_method": {
      "type": "string",
      "minLength": 1
    },
    "epistemic_classification": {
      "const": "DOCUMENTED_FINDING"
    },
    "provenance_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}