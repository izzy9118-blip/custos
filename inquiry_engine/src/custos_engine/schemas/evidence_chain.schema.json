{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Chain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_chain_id",
    "canonical_class",
    "target_entity",
    "ordered_evidence_record_ids",
    "chain_statement",
    "complete",
    "unresolved_gaps"
  ],
  "properties": {
    "evidence_chain_id": {
      "type": "string"
    },
    "canonical_class": {
      "const": "Evidence Chain"
    },
    "target_entity": {
      "type": "object"
    },
    "ordered_evidence_record_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "chain_statement": {
      "type": "string",
      "minLength": 1
    },
    "complete": {
      "type": "boolean"
    },
    "unresolved_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}