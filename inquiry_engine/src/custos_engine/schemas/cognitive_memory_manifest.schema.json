{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cognitive Memory Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_id",
    "version",
    "release_status",
    "repository_full_name",
    "repository_commit",
    "governing_specification_ids",
    "taxonomy_source",
    "procedure_source",
    "included_components",
    "excluded_component_ids",
    "known_conflicts",
    "permitted_engine_mode",
    "fixity_sha256",
    "responsible_authority_id"
  ],
  "properties": {
    "manifest_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "release_status": {
      "enum": [
        "DEVELOPMENT",
        "RELEASED",
        "WITHDRAWN"
      ]
    },
    "repository_full_name": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "repository_commit": {
      "type": "string",
      "minLength": 7
    },
    "governing_specification_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "taxonomy_source": {
      "type": "object"
    },
    "procedure_source": {
      "type": "object"
    },
    "included_components": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "excluded_component_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "permitted_engine_mode": {
      "enum": [
        "DEVELOPMENT",
        "PRODUCTION"
      ]
    },
    "predecessor_manifest_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "fixity_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "released_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "responsible_authority_id": {
      "type": "string"
    }
  }
}