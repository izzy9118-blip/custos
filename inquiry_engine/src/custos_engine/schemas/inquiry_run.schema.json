{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiry Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "mode",
    "initiating_question",
    "documentary_boundary",
    "repository_full_name",
    "git_commit",
    "cognitive_memory_manifest_id",
    "governing_specification_ids",
    "current_state"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "DEVELOPMENT",
        "PRODUCTION"
      ]
    },
    "initiating_question": {
      "type": "string",
      "minLength": 1
    },
    "documentary_boundary": {
      "type": "string",
      "minLength": 1
    },
    "repository_full_name": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "git_commit": {
      "type": "string",
      "minLength": 7
    },
    "cognitive_memory_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "projection_manifest_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "governing_specification_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_entity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_state": {
      "type": "string"
    },
    "state_history": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "observation_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hypothesis_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_chain_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_statement_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reasoning_record_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unresolved_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "termination_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "audit_history": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
