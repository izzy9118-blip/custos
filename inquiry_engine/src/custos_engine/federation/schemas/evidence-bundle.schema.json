{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:custos:federation:evidence-bundle:1.0.0",
  "title": "Custos Federation Evidence Bundle",
  "description": "A content-addressed selection of bounded excerpts that Custos re-reads from immutable Git commits before an Assembly inquiry.",
  "$comment": "Schema validation establishes structure only. The adapter also verifies bundle integrity, line-range order, Git reachability, exact excerpt bytes, excerpt SHA-256, identifier uniqueness, and total input limits.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "bundle_id",
    "bundle_version",
    "created_at",
    "repository_full_name",
    "items",
    "integrity"
  ],
  "properties": {
    "contract_version": {
      "const": "1.0.0"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^EVB-[A-Z0-9][A-Z0-9._-]{2,127}$"
    },
    "bundle_version": {
      "$ref": "#/$defs/semanticVersion"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "repository_full_name": {
      "const": "izzy9118-blip/custos"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "canonical_id",
          "git_commit",
          "path",
          "start_line",
          "end_line",
          "sha256",
          "source_role",
          "source_classification",
          "direct_or_derived",
          "citation",
          "support_summary"
        ],
        "properties": {
          "evidence_id": {
            "$ref": "#/$defs/localReference"
          },
          "canonical_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "git_commit": {
            "$ref": "#/$defs/gitCommit"
          },
          "path": {
            "$ref": "#/$defs/repositoryPath"
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "source_role": {
            "enum": [
              "PRIMARY",
              "SECONDARY",
              "REPOSITORY_CONTEXT"
            ]
          },
          "source_classification": {
            "enum": [
              "PRIMARY",
              "SECONDARY",
              "REPOSITORY_GOVERNANCE",
              "DERIVED_RETRIEVAL",
              "OTHER"
            ]
          },
          "direct_or_derived": {
            "enum": [
              "DIRECT",
              "DERIVED"
            ]
          },
          "citation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "support_summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 5000
          }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hash_algorithm",
        "canonicalization",
        "bundle_sha256"
      ],
      "properties": {
        "hash_algorithm": {
          "const": "SHA-256"
        },
        "canonicalization": {
          "const": "RFC8785"
        },
        "bundle_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "SHA-256 of the RFC 8785 canonical form of the complete bundle with the integrity object omitted."
        }
      }
    }
  },
  "$defs": {
    "semanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "repositoryPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*//)(?!.*(?:^|/)(?:\\.|\\.\\.)(?:/|$))[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
    },
    "localReference": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9._]+)+$",
      "maxLength": 200
    }
  }
}
